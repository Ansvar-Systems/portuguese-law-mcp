{
  "$schema": "./golden-tests.schema.json",
  "version": "2.0",
  "mcp_name": "Portuguese Law MCP",
  "description": "Golden contract tests for the Portuguese Law MCP covering Lei 58/2019 (GDPR implementation), Lei 46/2018 (NIS transposition), Codigo das Sociedades Comerciais (CSC), Lei 109/2009 (Cybercrime), DL 7/2004 (eCommerce), Constituicao (digital rights), and Lei 16/2022 (Electronic Communications). 12 tests: 4 article retrieval, 3 search, 2 citation roundtrip, 1 EU cross-reference, 2 negative tests.",
  "tests": [
    {
      "id": "pt-001",
      "category": "article_retrieval",
      "description": "Retrieve Artigo 1 of Lei 58/2019 -- object and scope of the Portuguese GDPR implementation",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 58/2019",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Regulamento", "2016/679", "proteção"],
        "fields_present": ["content", "section"],
        "text_not_empty": true
      }
    },
    {
      "id": "pt-002",
      "category": "article_retrieval",
      "description": "Retrieve Artigo 6 of Lei 109/2009 (Cybercrime Law) -- acesso ilegitimo (unauthorized access)",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 109/2009",
        "section": "6"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["permissão", "autorizado", "sistema informático", "punido"],
        "fields_present": ["content", "section"],
        "text_not_empty": true
      }
    },
    {
      "id": "pt-003",
      "category": "article_retrieval",
      "description": "Retrieve Artigo 1 of the Codigo das Sociedades Comerciais (CSC) -- scope of commercial company law",
      "tool": "get_provision",
      "input": {
        "document_id": "Codigo das Sociedades Comerciais",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["sociedades comerciais", "sociedade"],
        "fields_present": ["content", "section"],
        "text_not_empty": true
      }
    },
    {
      "id": "pt-004",
      "category": "article_retrieval",
      "description": "Retrieve Artigo 1 of Lei 46/2018 -- object and scope of the NIS transposition (regime juridico da seguranca do ciberespaco)",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 46/2018",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["segurança", "ciberespaço", "Diretiva"],
        "fields_present": ["content", "section"],
        "text_not_empty": true
      }
    },
    {
      "id": "pt-005",
      "category": "search",
      "description": "Full-text search for 'dados pessoais' (personal data) returns provisions across multiple statutes",
      "tool": "search_legislation",
      "input": {
        "query": "dados pessoais"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 5,
        "any_result_contains": ["dados pessoais", "proteção", "tratamento"]
      }
    },
    {
      "id": "pt-006",
      "category": "search",
      "description": "Full-text search for 'ciberseguranca' (cybersecurity) returns NIS law and related provisions",
      "tool": "search_legislation",
      "input": {
        "query": "cibersegurança"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["cibersegurança", "segurança", "ciberespaço", "redes"]
      }
    },
    {
      "id": "pt-007",
      "category": "search",
      "description": "Full-text search for 'comercio eletronico' (electronic commerce) returns DL 7/2004 provisions",
      "tool": "search_legislation",
      "input": {
        "query": "comércio eletrónico"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["comércio", "eletrónico", "serviços"]
      }
    },
    {
      "id": "pt-008",
      "category": "citation_roundtrip",
      "description": "Provision for Lei 58/2019 Artigo 2 includes PGDL URL (pgdlisboa.pt) as source reference",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 58/2019",
        "section": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "pgdlisboa\\.pt",
        "text_not_empty": true
      }
    },
    {
      "id": "pt-009",
      "category": "citation_roundtrip",
      "description": "Provision for DL 7/2004 Artigo 1 includes source URL to PGDL",
      "tool": "get_provision",
      "input": {
        "document_id": "DL 7/2004",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Directiva", "2000/31/CE"],
        "text_not_empty": true
      }
    },
    {
      "id": "pt-010",
      "category": "eu_cross_reference",
      "description": "Lei 58/2019 is a direct GDPR implementation -- check_currency confirms it references EU regulation",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 58/2019",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Regulamento (UE) 2016/679", "Regulamento"]
      }
    },
    {
      "id": "pt-011",
      "category": "negative_test",
      "description": "Non-existent Portuguese law returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei Ficticia 9999/2099",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "pt-012",
      "category": "negative_test",
      "description": "Malformed article number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "Lei 58/2019",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
